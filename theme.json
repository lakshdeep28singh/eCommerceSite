{
  "version": 2,
  "settings": {
    "color": {
      "palette": [
        {
          "name": "EcoGreen",
          "slug": "eco-green",
          "color": "#2e7d32"
        },
        {
          "name": "EcoGreen Light",
          "slug": "eco-green-light",
          "color": "#60ad5e"
        },
        {
          "name": "EcoGreen Dark",
          "slug": "eco-green-dark",
          "color": "#1b5e20"
        },
        {
          "name": "EcoBeige",
          "slug": "eco-beige",
          "color": "#f5f0e8"
        },
        {
          "name": "EcoBrown",
          "slug": "eco-brown",
          "color": "#5d4037"
        },
        {
          "name": "White",
          "slug": "white",
          "color": "#ffffff"
        },
        {
          "name": "Off White",
          "slug": "off-white",
          "color": "#fafaf8"
        },
        {
          "name": "Dark",
          "slug": "dark",
          "color": "#1a1a1a"
        },
        {
          "name": "Mid Grey",
          "slug": "mid-grey",
          "color": "#6b7280"
        },
        {
          "name": "Light Grey",
          "slug": "light-grey",
          "color": "#f3f4f6"
        }
      ]
    },
    "layout": {
      "contentSize": "800px",
      "wideSize": "1200px"
    },
    "typography": {
      "fontFamilies": [
        {
          "name": "Inter",
          "slug": "inter",
          "fontFamily": "Inter, sans-serif",
          "fontFace": [
            {
              "src": ["https://fonts.gstatic.com/s/inter/v13/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuLyfAZ9hiA.woff2"],
              "fontWeight": "400",
              "fontStyle": "normal"
            },
            {
              "src": ["https://fonts.gstatic.com/s/inter/v13/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuI6fAZ9hiA.woff2"],
              "fontWeight": "700",
              "fontStyle": "normal"
            }
          ]
        },
        {
          "name": "Lora",
          "slug": "lora",
          "fontFamily": "Lora, serif",
          "fontFace": [
            {
              "src": ["https://fonts.gstatic.com/s/lora/v26/0QI6MX1D_JOxE7fSyjlE.woff2"],
              "fontWeight": "400",
              "fontStyle": "normal"
            },
            {
              "src": ["https://fonts.gstatic.com/s/lora/v26/0QI6MX1D_JOxE7fSyjlE.woff2"],
              "fontWeight": "700",
              "fontStyle": "normal"
            }
          ]
        }
      ],
      "fontSizes": [
        { "name": "Small",        "slug": "small",        "size": "0.875rem" },
        { "name": "Normal",       "slug": "normal",       "size": "1rem"     },
        { "name": "Medium",       "slug": "medium",       "size": "1.125rem" },
        { "name": "Large",        "slug": "large",        "size": "1.5rem"   },
        { "name": "X-Large",      "slug": "x-large",      "size": "2rem"     },
        { "name": "XX-Large",     "slug": "xx-large",     "size": "2.75rem"  }
      ]
    },
    "spacing": {
      "spacingSizes": [
        { "name": "XS",   "slug": "xs",   "size": "0.5rem"  },
        { "name": "SM",   "slug": "sm",   "size": "1rem"    },
        { "name": "MD",   "slug": "md",   "size": "1.5rem"  },
        { "name": "LG",   "slug": "lg",   "size": "2.5rem"  },
        { "name": "XL",   "slug": "xl",   "size": "4rem"    },
        { "name": "XXL",  "slug": "xxl",  "size": "6rem"    }
      ],
      "units": ["%", "px", "em", "rem", "vh", "vw"]
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "custom": {
      "lineHeight": {
        "small":  "1.3",
        "medium": "1.6",
        "large":  "1.9"
      }
    }
  },
  "styles": {
    "color": {
      "background": "#fafaf8",
      "text": "#1a1a1a"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "fontSize": "var(--wp--preset--font-size--normal)",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "1.5rem"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--eco-green)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--eco-green-dark)"
          }
        }
      },
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--lora)",
          "fontSize": "var(--wp--preset--font-size--xx-large)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        },
        "color": { "text": "var(--wp--preset--color--eco-green-dark)" }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--lora)",
          "fontSize": "var(--wp--preset--font-size--x-large)",
          "fontWeight": "700",
          "lineHeight": "1.3"
        },
        "color": { "text": "var(--wp--preset--color--eco-green-dark)" }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--lora)",
          "fontSize": "var(--wp--preset--font-size--large)",
          "fontWeight": "700",
          "lineHeight": "1.4"
        },
        "color": { "text": "var(--wp--preset--color--dark)" }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontSize": "var(--wp--preset--font-size--medium)",
          "fontWeight": "700"
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontSize": "var(--wp--preset--font-size--normal)",
          "fontWeight": "700",
          "textTransform": "uppercase",
          "letterSpacing": "0.05em"
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontSize": "var(--wp--preset--font-size--small)",
          "fontWeight": "700",
          "textTransform": "uppercase",
          "letterSpacing": "0.08em"
        },
        "color": { "text": "var(--wp--preset--color--mid-grey)" }
      },
      "button": {
        "color": {
          "text": "var(--wp--preset--color--white)",
          "background": "var(--wp--preset--color--eco-green)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontWeight": "700",
          "fontSize": "var(--wp--preset--font-size--small)",
          "textTransform": "uppercase",
          "letterSpacing": "0.05em"
        },
        "border": {
          "radius": "4px"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "bottom": "0.75rem",
            "left": "1.5rem",
            "right": "1.5rem"
          }
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--eco-green-dark)"
          }
        }
      }
    },
    "blocks": {
      "core/paragraph": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontSize": "var(--wp--preset--font-size--normal)",
          "lineHeight": "1.7"
        },
        "spacing": {
          "margin": { "bottom": "1rem" }
        }
      },
      "core/heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--lora)"
        },
        "spacing": {
          "margin": { "top": "1.5rem", "bottom": "0.75rem" }
        }
      },
      "core/list": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontSize": "var(--wp--preset--font-size--normal)",
          "lineHeight": "1.7"
        },
        "spacing": {
          "margin": { "bottom": "1rem" },
          "padding": { "left": "1.5rem" }
        }
      },
      "core/list-item": {
        "spacing": {
          "margin": { "bottom": "0.4rem" }
        }
      },
      "core/quote": {
        "color": {
          "background": "var(--wp--preset--color--eco-beige)",
          "text": "var(--wp--preset--color--eco-brown)"
        },
        "border": {
          "left": {
            "color": "var(--wp--preset--color--eco-green)",
            "width": "5px",
            "style": "solid"
          },
          "radius": "0 4px 4px 0"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--lora)",
          "fontSize": "var(--wp--preset--font-size--medium)",
          "fontStyle": "italic",
          "lineHeight": "1.7"
        },
        "spacing": {
          "padding": {
            "top": "1.5rem",
            "bottom": "1.5rem",
            "left": "2rem",
            "right": "1.5rem"
          },
          "margin": { "top": "1.5rem", "bottom": "1.5rem" }
        }
      },
      "core/pullquote": {
        "color": {
          "background": "var(--wp--preset--color--eco-green-dark)",
          "text": "var(--wp--preset--color--white)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--lora)",
          "fontSize": "var(--wp--preset--font-size--large)",
          "fontStyle": "italic",
          "lineHeight": "1.5",
          "textAlign": "center"
        },
        "border": {
          "top": { "color": "var(--wp--preset--color--eco-green-light)", "width": "3px", "style": "solid" },
          "bottom": { "color": "var(--wp--preset--color--eco-green-light)", "width": "3px", "style": "solid" }
        },
        "spacing": {
          "padding": {
            "top": "3rem",
            "bottom": "3rem",
            "left": "2rem",
            "right": "2rem"
          },
          "margin": { "top": "2rem", "bottom": "2rem" }
        }
      },
      "core/verse": {
        "color": {
          "background": "var(--wp--preset--color--light-grey)",
          "text": "var(--wp--preset--color--dark)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--lora)",
          "fontSize": "var(--wp--preset--font-size--normal)",
          "lineHeight": "2"
        },
        "border": {
          "radius": "4px"
        },
        "spacing": {
          "padding": {
            "top": "1.5rem",
            "bottom": "1.5rem",
            "left": "1.5rem",
            "right": "1.5rem"
          }
        }
      },
      "core/code": {
        "color": {
          "background": "#1a1a2e",
          "text": "#60ad5e"
        },
        "typography": {
          "fontFamily": "monospace",
          "fontSize": "var(--wp--preset--font-size--small)",
          "lineHeight": "1.8"
        },
        "border": {
          "radius": "6px",
          "left": {
            "color": "var(--wp--preset--color--eco-green-light)",
            "width": "4px",
            "style": "solid"
          }
        },
        "spacing": {
          "padding": {
            "top": "1.25rem",
            "bottom": "1.25rem",
            "left": "1.5rem",
            "right": "1.5rem"
          },
          "margin": { "top": "1.5rem", "bottom": "1.5rem" }
        }
      },
      "core/preformatted": {
        "color": {
          "background": "var(--wp--preset--color--light-grey)",
          "text": "var(--wp--preset--color--dark)"
        },
        "typography": {
          "fontFamily": "monospace",
          "fontSize": "var(--wp--preset--font-size--small)",
          "lineHeight": "1.8"
        },
        "border": {
          "radius": "4px",
          "color": "#d1d5db",
          "width": "1px",
          "style": "solid"
        },
        "spacing": {
          "padding": {
            "top": "1.25rem",
            "bottom": "1.25rem",
            "left": "1.25rem",
            "right": "1.25rem"
          }
        }
      },
      "core/table": {
        "color": {
          "text": "var(--wp--preset--color--dark)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontSize": "var(--wp--preset--font-size--small)"
        },
        "border": {
          "color": "#d1d5db",
          "width": "1px",
          "style": "solid"
        }
      },
      "core/separator": {
        "color": {
          "text": "var(--wp--preset--color--eco-green)"
        },
        "border": {
          "color": "var(--wp--preset--color--eco-green)",
          "width": "2px",
          "style": "solid"
        },
        "spacing": {
          "margin": { "top": "2rem", "bottom": "2rem" }
        }
      },
      "core/details": {
        "color": {
          "background": "var(--wp--preset--color--eco-beige)"
        },
        "border": {
          "radius": "4px",
          "color": "var(--wp--preset--color--eco-green)",
          "width": "1px",
          "style": "solid"
        },
        "spacing": {
          "padding": {
            "top": "1rem",
            "bottom": "1rem",
            "left": "1.25rem",
            "right": "1.25rem"
          }
        }
      },
      "core/site-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--lora)",
          "fontSize": "var(--wp--preset--font-size--large)",
          "fontWeight": "700"
        },
        "color": {
          "text": "var(--wp--preset--color--eco-green-dark)"
        }
      },
      "core/navigation": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontSize": "var(--wp--preset--font-size--small)",
          "fontWeight": "600",
          "textTransform": "uppercase",
          "letterSpacing": "0.05em"
        },
        "color": {
          "text": "var(--wp--preset--color--dark)"
        }
      },
      "core/post-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--lora)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        },
        "color": {
          "text": "var(--wp--preset--color--eco-green-dark)"
        }
      },
      "core/button": {
        "color": {
          "background": "var(--wp--preset--color--eco-green)",
          "text": "var(--wp--preset--color--white)"
        },
        "typography": {
          "fontWeight": "700",
          "textTransform": "uppercase",
          "letterSpacing": "0.05em",
          "fontSize": "var(--wp--preset--font-size--small)"
        },
        "border": {
          "radius": "4px"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "bottom": "0.75rem",
            "left": "1.75rem",
            "right": "1.75rem"
          }
        }
      }
    }
  }
}
